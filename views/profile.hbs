<div class="row mb-5">
    <div class="col-md-4">
        {{#if user.image}}
            <img class="img-responsive center-block mb-5" src="{{user.image}}"
                style="width: 250px; transition: opacity 0.5s; opacity:0;" onload="this.style.opacity=1;">
        {{else}}
            <img class="img-responsive center-block mb-5 opacity-25" src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcTdO2DCDcfM7yDAtEo797CkSw_njibgz-lOgw&s"
                style="width: 250px; transition: opacity 0.5s; opacity:0;" onload="this.style.opacity=0.25;">
        {{/if}}
    </div>
    <div class="col-md-8">
        <h1>{{user.name}}</h1>
        <p>{{user.email}}</p>
    </div>
</div>
<a href="/users/{{user.id}}/edit" class="btn btn-primary">Edit</a>